{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Vote Response Schema",
  "description": "JSON schema for validating vote response structure",
  "type": "object",
  "required": ["pollId", "success", "message"],
  "properties": {
    "pollId": {
      "type": "string",
      "pattern": "^[0-9a-f]{8}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{4}-[0-9a-f]{12}$",
      "description": "UUID format poll identifier"
    },
    "success": {
      "type": "boolean",
      "description": "Whether the vote was successful"
    },
    "message": {
      "type": "string",
      "minLength": 1,
      "description": "Response message"
    },
    "updatedVotes": {
      "type": "array",
      "items": {
        "type": "integer",
        "minimum": 0
      },
      "description": "Updated vote counts after the vote"
    }
  },
  "additionalProperties": false
}
