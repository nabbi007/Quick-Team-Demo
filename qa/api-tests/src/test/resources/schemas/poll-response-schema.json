{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Poll Response Schema",
  "description": "JSON schema for validating poll response structure based on OpenAPI PollResponse",
  "type": "object",
  "required": ["id", "title", "question", "creatorName", "status", "maxSelections", "expiresAt", "createdAt", "totalVotes", "options"],
  "properties": {
    "id": {
      "type": "integer",
      "description": "Poll identifier"
    },
    "title": {
      "type": "string",
      "maxLength": 255,
      "description": "The poll title"
    },
    "question": {
      "type": "string",
      "maxLength": 255,
      "description": "The poll question"
    },
    "description": {
      "type": ["string", "null"],
      "description": "Poll description (optional)"
    },
    "creatorName": {
      "type": "string",
      "minLength": 1,
      "description": "Name of the poll creator"
    },
    "status": {
      "type": "string",
      "enum": ["ACTIVE", "CLOSED"],
      "description": "Poll status"
    },
    "maxSelections": {
      "type": "integer",
      "minimum": 1,
      "description": "Maximum number of options that can be selected"
    },
    "expiresAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime when poll expires"
    },
    "createdAt": {
      "type": "string",
      "format": "date-time",
      "description": "ISO 8601 datetime when poll was created"
    },
    "totalVotes": {
      "type": "integer",
      "minimum": 0,
      "description": "Total number of votes across all options"
    },
    "options": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "text", "voteCount", "percentage"],
        "properties": {
          "id": {
            "type": "integer",
            "description": "Option identifier"
          },
          "text": {
            "type": "string",
            "minLength": 1,
            "description": "Option text"
          },
          "voteCount": {
            "type": "integer",
            "minimum": 0,
            "description": "Number of votes for this option"
          },
          "percentage": {
            "type": "number",
            "minimum": 0,
            "maximum": 100,
            "description": "Percentage of total votes"
          }
        },
        "additionalProperties": false
      },
      "description": "List of poll options with vote counts and percentages"
    }
  },
  "additionalProperties": false
}
