# QuickPoll Data Engineering — Environment Variables
# Copy this file to .env and fill in your values
# Never commit .env to git

# ─── PostgreSQL (shared with backend dev) ─────────────────────
# Get connection details from your backend dev / shared DB host
DB_HOST=<shared-db-host>
DB_PORT=5432
DB_NAME=quickpoll
DB_USER=<db-user>
DB_PASSWORD=<db-password>

# ─── Kafka ────────────────────────────────────────────────────
# Use localhost:9092 for local dev (Kafka exposed via docker-compose ports)
# Use kafka:9092 when running inside Docker Compose network
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_VOTE_EVENTS=vote_events
KAFKA_TOPIC_POLL_EVENTS=poll_events
KAFKA_GROUP_ID=quickpoll-analytics

# ─── Pipeline ─────────────────────────────────────────────────
LOG_LEVEL=DEBUG

# ─── Cloudflare R2 (Dead-Letter Queue) ────────────────────────
# Create a bucket in the Cloudflare R2 dashboard first, then fill in below.
# Endpoint format: https://<ACCOUNT_ID>.r2.cloudflarestorage.com
R2_ENDPOINT_URL=https://<account-id>.r2.cloudflarestorage.com
# Generate an API token under R2 → Manage R2 API tokens
R2_ACCESS_KEY_ID=<r2-access-key-id>
R2_SECRET_ACCESS_KEY=<r2-secret-access-key>
# Name of the bucket you created for failed events
R2_DLQ_BUCKET=quickpoll-dlq
